{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        "lastPostTimestamp": {
          ".validate": "newData.isNumber() && (!data.exists() || newData.val() >= data.val() + 5000)"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "messages": {
      ".read": true,
      ".indexOn": [
        "timestamp"
      ],
      "$message_id": {
        ".write": "auth != null && (!data.exists() || data.child('authorId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['text', 'author', 'authorId', 'timestamp'])",
        "text": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 250"
        },
        "author": {
          ".validate": "data.exists() ? newData.val() === data.val() : (newData.isString() && newData.val().length > 0)"
        },
        "authorId": {
          ".validate": "newData.val() === auth.uid"
        },
        "timestamp": {
          ".validate": "data.exists() ? newData.val() === data.val() : (newData.val() <= now && newData.val() >= now - 30000)"
        },
        "editedAt": {
          ".validate": "newData.isNumber()"
        },
        "replies": {
          "$reply_id": {
            ".write": "auth != null && (!data.exists() || data.child('authorId').val() === auth.uid)",
            ".validate": "newData.hasChildren(['text', 'author', 'authorId', 'timestamp'])",
            "text": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 250"
            },
            "author": {
              ".validate": "data.exists() ? newData.val() === data.val() : (newData.isString() && newData.val().length > 0)"
            },
            "authorId": {
              ".validate": "newData.val() === auth.uid"
            },
            "timestamp": {
              ".validate": "data.exists() ? newData.val() === data.val() : (newData.val() <= now && newData.val() >= now - 30000)"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}