{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        "lastPostTimestamp": {
          ".validate": "newData.isNumber() && (!data.exists() || newData.val() >= data.val() + 5000)"
        },
        "lastFlagTimestamp": {
          ".validate": "newData.isNumber() && (!data.exists() || newData.val() >= data.val() + 6000)"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "typing": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && auth.uid == $uid",
        ".validate": "newData.hasChildren(['name', 'timestamp'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 100"
        },
        "timestamp": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "messages": {
      ".read": true,
      ".indexOn": [
        "timestamp"
      ],
      "$message_id": {
        ".write": "auth != null && (!data.exists() || data.child('authorId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['text', 'author', 'authorId', 'timestamp'])",
        "text": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 250"
        },
        "author": {
          ".validate": "data.exists() ? newData.val() === data.val() : newData.val() === auth.token.name"
        },
        "authorId": {
          ".validate": "newData.val() === auth.uid"
        },
        "timestamp": {
          ".validate": "data.exists() ? newData.val() === data.val() : (newData.val() <= now && newData.val() >= now - 30000)"
        },
        "editedAt": {
          ".validate": "newData.isNumber()"
        },
        "photoURL": {
          ".validate": "newData.isString()"
        },
        "replies": {
          "$reply_id": {
            ".write": "auth != null && (!data.exists() || data.child('authorId').val() === auth.uid)",
            ".validate": "newData.hasChildren(['text', 'author', 'authorId', 'timestamp'])",
            "text": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 250"
            },
            "author": {
              ".validate": "data.exists() ? newData.val() === data.val() : newData.val() === auth.token.name"
            },
            "authorId": {
              ".validate": "newData.val() === auth.uid"
            },
            "timestamp": {
              ".validate": "data.exists() ? newData.val() === data.val() : (newData.val() <= now && newData.val() >= now - 30000)"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "reportCounts": {
      ".read": true,
      "$message_id": {
        ".write": "auth != null && (newData.val() > data.val() ? root.child('reports').child($message_id).child(auth.uid).exists() : !root.child('reports').child($message_id).child(auth.uid).exists())",
        ".validate": "newData.isNumber() && newData.val() >= 0 && (data.exists() ? (newData.val() == data.val() + 1 || newData.val() == data.val() - 1) : newData.val() == 1)"
      }
    },
    "reports": {
      "$message_id": {
        "$reporter_uid": {
          ".read": "auth != null && (auth.uid == $reporter_uid || auth.uid == root.child('messages').child($message_id).child('authorId').val())",
          ".write": "auth != null && auth.uid == $reporter_uid",
          ".validate": "!newData.exists() || newData.hasChildren(['reportedAt', 'authorId'])",
          "reportedAt": {
            ".validate": "newData.isNumber()"
          },
          "authorId": {
            ".validate": "newData.isString() && newData.val() == root.child('messages').child($message_id).child('authorId').val()"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    }
  }
}
